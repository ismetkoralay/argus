# Copy to .env (git-ignored) for local development.
# Secrets here are for local dev only — never commit real values.
# In CI/k8s these come from GitHub Actions/Kubernetes Secrets, not this file.

# Port the HTTP server listens on. Must be an integer in [1, 65535].
PORT=8080

# GitHub App ID, from the app's settings page. Required; must be > 0.
GITHUB_APP_ID=

# GitHub App private key (PEM), generated from the app's settings page.
# .env files can't hold real newlines cleanly, so paste it as ONE line with
# literal \n in place of line breaks (the app unescapes them at startup):
#   GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n...\n-----END RSA PRIVATE KEY-----
# To generate that from the downloaded .pem file:
#   awk 'NF {printf "%s\\n", $0}' your-app.private-key.pem
# Required.
GITHUB_APP_PRIVATE_KEY=

# Webhook secret configured on the GitHub App. Required.
GITHUB_WEBHOOK_SECRET=

# Base URL of the Ollama server used for reviews. Must be an absolute
# http(s) URL. Defaults to a locally-run `ollama serve`; under
# docker-compose this instead points at the host machine (see
# docker-compose.yml) since the container's own localhost isn't the host's.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use for reviews.
OLLAMA_MODEL=qwen2.5-coder

# Log verbosity: debug, info, warn, or error. Empty defaults to info; any
# other value fails startup.
LOG_LEVEL=info
