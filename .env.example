# Copy to .env (git-ignored) for local development.
# Secrets here are for local dev only — never commit real values.
# In CI/k8s these come from GitHub Actions/Kubernetes Secrets, not this file.

PORT=8080

# GitHub App ID, from the app's settings page.
GITHUB_APP_ID=

# GitHub App private key (PEM), generated from the app's settings page.
# .env files can't hold real newlines cleanly, so paste it as ONE line with
# literal \n in place of line breaks (the app unescapes them at startup):
#   GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n...\n-----END RSA PRIVATE KEY-----
# To generate that from the downloaded .pem file:
#   awk 'NF {printf "%s\\n", $0}' your-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=

# Webhook secret configured on the GitHub App.
GITHUB_WEBHOOK_SECRET=
